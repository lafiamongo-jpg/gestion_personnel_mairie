@inherits LayoutComponentBase
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Authorization
@using GestionPersonnelMairie.Services
@inject AuthStateService AuthState

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>
    <main>
        <div class="top-row px-4 d-flex align-items-center justify-content-end gap-3">
            <AuthorizeView>
                <Authorized>
                    <span class="text-muted" style="font-size:0.85rem;">
                        👤 <strong>@(AuthState.NomComplet ?? context.User.Identity?.Name)</strong>
                        @if (!string.IsNullOrEmpty(AuthState.Role))
                        {
                            <span class="badge ms-1 @(AuthState.EstAdmin ? "bg-danger" : "bg-primary")" style="font-size:0.72rem;">
                                @AuthState.Role
                            </span>
                        }
                    </span>
                    <LogoutButton />
                </Authorized>
            </AuthorizeView>
        </div>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
