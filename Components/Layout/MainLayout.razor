@inherits LayoutComponentBase
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Components.Authorization
@using GestionPersonnelMairie.Services
@inject AuthStateService AuthState

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>
    <main>
        <div class="top-row px-4 d-flex align-items-center justify-content-between">
            <div class="top-brand d-none d-md-flex align-items-center gap-2">
                <span class="top-brand-icon">🏛️</span>
                <div>
                    <div class="top-brand-title">Commune de Banikoara</div>
                    <div class="top-brand-sub">Système de Gestion du Personnel</div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                <AuthorizeView>
                    <Authorized>
                        <span class="user-greeting">
                            <strong>@(AuthState.NomComplet ?? context.User.Identity?.Name)</strong>
                            @if (!string.IsNullOrEmpty(AuthState.Role))
                            {
                                <span class="role-badge ms-2 @GetRoleBadgeClass(AuthState.Role)">
                                    @AuthState.Role
                                </span>
                            }
                        </span>
                        <LogoutButton />
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
        <article class="content @(IsHome ? "content-home" : "")">
            @Body
        </article>
    </main>
</div>

@code {
    private bool IsHome
    {
        get
        {
            var path = Navigation.ToBaseRelativePath(Navigation.Uri);
            return string.IsNullOrEmpty(path);
        }
    }

    private static string GetRoleBadgeClass(string? role) => role switch
    {
        GestionPersonnelMairie.Core.Constants.Roles.SuperAdmin => "role-badge--super",
        GestionPersonnelMairie.Core.Constants.Roles.Admin => "role-badge--admin",
        _ => "role-badge--agent"
    };
}
