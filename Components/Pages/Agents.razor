@page "/agents"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using GestionPersonnelMairie.Core.Constants
@using GestionPersonnelMairie.Core.Enums
@using GestionPersonnelMairie.Models
@using GestionPersonnelMairie.Services
@inject AgentService AgentService
@inject UtilisateurService UtilisateurService

<PageTitle>Gestion des Agents</PageTitle>

<PolicyGuard RequireSuperAdmin="true">

<!-- Popup de succès -->
@if (showSucces)
{
    <div style="position:fixed; top:20px; right:20px; z-index:9999;">
        <div class="alert alert-success alert-dismissible shadow" style="min-width:300px;">
            <strong>✅ Succès !</strong> @succesMessage
            <button type="button" class="btn-close" @onclick="() => showSucces = false"></button>
        </div>
    </div>
}

<div class="container-fluid py-4">

    <!-- En-tête -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>👥 Gestion des Agents</h2>
        <button class="btn btn-primary" @onclick="() => OuvrirModal()">
            ➕ Ajouter un agent
        </button>
    </div>

    <!-- Filtres -->
    <div class="row mb-3 g-2">
        <div class="col-md-4">
            <input type="text" class="form-control" placeholder="🔍 Rechercher par nom ou email..."
                   @bind="recherche" @bind:event="oninput" />
        </div>
        <div class="col-md-2">
            <select class="form-select" @bind="serviceFiltre">
                <option value="0">Tous les services</option>
                @foreach (var s in services)
                {
                    <option value="@s.IdService">@s.NomService</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select class="form-select" @bind="posteFiltre">
                <option value="0">Tous les postes</option>
                @foreach (var p in postes)
                {
                    <option value="@p.IdPoste">@p.NomPoste</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select class="form-select" @bind="statutFiltre">
                <option value="">Tous les statuts</option>
                <option value="@StatutAgent.Actif">Actif</option>
                <option value="@StatutAgent.EnConge">En congé</option>
                <option value="@StatutAgent.Suspendu">Suspendu</option>
                <option value="@StatutAgent.Archive">Archivé</option>
            </select>
        </div>
    </div>

    <!-- Tableau -->
    <div class="table-responsive">
        <table class="table table-hover table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Nom complet</th>
                    <th>Email</th>
                    <th>Téléphone</th>
                    <th>Département</th>
                    <th>Statut</th>
                    <th>Compte</th>
                    <th>Date embauche</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!agentsFiltres.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center text-muted">Aucun agent trouvé.</td>
                    </tr>
                }
                @foreach (var agent in agentsFiltres)
                {
                    <tr>
                        <td>@agent.NomComplet</td>
                        <td>@agent.Email</td>
                        <td>@agent.Telephone</td>
                        <td>@agent.Departement</td>
                        <td>
                            <span class="statut-pill @GetStatutClass(agent.Statut)">
                                @(string.IsNullOrWhiteSpace(agent.Statut) ? StatutAgent.Actif : agent.Statut)
                            </span>
                        </td>
                        <td>
                            @if (agentsAvecCompteVerifie.Contains(agent.Id))
                            {
                                <span class="compte-pill compte-pill--ok">Compte actif</span>
                            }
                            else if (agentsAvecCompteEnAttente.Contains(agent.Id))
                            {
                                <span class="compte-pill compte-pill--pending">En attente</span>
                            }
                            else
                            {
                                <span class="compte-pill compte-pill--none">Sans compte</span>
                            }
                        </td>
                        <td>@agent.DateEmbauche.ToShortDateString()</td>
                        <td>
                            <button class="btn btn-sm btn-warning me-1" title="Modifier" @onclick="() => OuvrirModal(agent)">✏️</button>
                            @if (agentsAvecCompteEnAttente.Contains(agent.Id))
                            {
                                <button class="btn btn-sm btn-info me-1" title="Renvoyer l'email d'activation"
                                        @onclick="() => RenvoyerVerification(agent.Id)">📧</button>
                            }
                            <button class="btn btn-sm btn-danger" title="Supprimer" @onclick="() => DemanderSuppression(agent)">🗑️</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Ajouter / Modifier -->
@if (showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(agentEdite.Id == 0 ? "Ajouter un agent" : "Modifier l'agent")</h5>
                    <button type="button" class="btn-close" @onclick="FermerModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Nom</label>
                            <input class="form-control" @bind="agentEdite.Nom" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Prénom</label>
                            <input class="form-control" @bind="agentEdite.Prenom" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" @bind="agentEdite.Email" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Téléphone</label>
                            <input class="form-control" @bind="agentEdite.Telephone" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Adresse</label>
                            <input class="form-control" @bind="agentEdite.Adresse" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Sexe</label>
                            <select class="form-select" @bind="agentEdite.Sexe">
                                <option value="">-- Choisir --</option>
                                <option value="M">Masculin</option>
                                <option value="F">Féminin</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Date de naissance</label>
                            <input type="date" class="form-control" @bind="agentEdite.DateNaissance" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Département</label>
                            <select class="form-select" @bind="agentEdite.Departement">
                                <option value="">-- Choisir un département --</option>
                                <option value="Alibori">Alibori</option>
                                <option value="Atacora">Atacora</option>
                                <option value="Atlantique">Atlantique</option>
                                <option value="Borgou">Borgou</option>
                                <option value="Collines">Collines</option>
                                <option value="Couffo">Couffo</option>
                                <option value="Donga">Donga</option>
                                <option value="Littoral">Littoral</option>
                                <option value="Mono">Mono</option>
                                <option value="Ouémé">Ouémé</option>
                                <option value="Plateau">Plateau</option>
                                <option value="Zou">Zou</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Statut</label>
                            <select class="form-select" @bind="agentEdite.Statut">
                                <option value="@StatutAgent.Actif">Actif</option>
                                <option value="@StatutAgent.EnConge">En congé</option>
                                <option value="@StatutAgent.Suspendu">Suspendu</option>
                                <option value="@StatutAgent.Archive">Archivé</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Date d'embauche</label>
                            <input type="date" class="form-control" @bind="agentEdite.DateEmbauche" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Salaire</label>
                            <input type="number" class="form-control" @bind="agentEdite.Salaire" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Service</label>
                            <select class="form-select" @bind="agentEdite.IdService">
                                <option value="0">-- Choisir --</option>
                                @foreach (var s in services)
                                {
                                    <option value="@s.IdService">@s.NomService</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Poste</label>
                            <select class="form-select" @bind="agentEdite.IdPoste">
                                <option value="0">-- Choisir --</option>
                                @foreach (var p in postes)
                                {
                                    <option value="@p.IdPoste">@p.NomPoste</option>
                                }
                            </select>
                        </div>
                    </div>

                    @if (agentEdite.Id == 0)
                    {
                        <hr class="my-3" />
                        <h6 class="mb-2">Compte de connexion</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">Rôle du compte</label>
                                <select class="form-select" @bind="roleCompteId">
                                    @foreach (var r in roles)
                                    {
                                        <option value="@r.IdRole">@r.NomRole — @r.Description</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-6 d-flex align-items-end">
                                <div class="alert alert-info py-2 mb-0 w-100" style="font-size:0.82rem;">
                                    Mot de passe initial : <strong>@AppDefaults.MotDePasseInitial</strong><br />
                                    Un email d'activation sera envoyé à l'adresse indiquée.
                                </div>
                            </div>
                        </div>
                    }

                    @if (erreurMessage != null)
                    {
                        <div class="alert alert-danger mt-3">@erreurMessage</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="FermerModal">Annuler</button>
                    <button class="btn btn-primary" @onclick="Sauvegarder">💾 Sauvegarder</button>
                </div>
            </div>
        </div>
    </div>
}

<ConfirmDialog Visible="showConfirmDelete"
               Title="Supprimer cet agent ?"
               Message="@confirmMessage"
               ConfirmLabel="Supprimer"
               OnConfirm="ConfirmerSuppression"
               OnCancel="() => showConfirmDelete = false" />

</PolicyGuard>

@code {
    private List<Agent> agents = new();
    private List<Service> services = new();
    private List<Poste> postes = new();
    private List<Role> roles = new();
    private HashSet<int> agentsAvecCompteVerifie = new();
    private HashSet<int> agentsAvecCompteEnAttente = new();
    // IdAgent → IdUtilisateur (pour renvoyer la vérification)
    private Dictionary<int, int> agentIdVersUtilisateurId = new();
    private string recherche = "";
    private string statutFiltre = "";
    private int serviceFiltre;
    private int posteFiltre;
    private bool showModal = false;
    private bool showSucces = false;
    private string succesMessage = "";
    private Agent agentEdite = new();
    private string? erreurMessage = null;
    private int roleCompteId;
    private bool showConfirmDelete;
    private int agentASupprimer;
    private string confirmMessage = "";

    private List<Agent> agentsFiltres => AgentService.Search(
        recherche,
        serviceFiltre > 0 ? serviceFiltre : null,
        posteFiltre > 0 ? posteFiltre : null,
        string.IsNullOrEmpty(statutFiltre) ? null : statutFiltre);

    protected override void OnInitialized()
    {
        ChargerDonnees();
    }

    private void ChargerDonnees()
    {
        agents = AgentService.GetAll();
        services = AgentService.GetServices();
        postes = AgentService.GetPostes();
        roles = UtilisateurService.GetRoles();
        var utilisateurs = UtilisateurService.GetAll().Where(u => u.IdAgent.HasValue).ToList();
        agentsAvecCompteVerifie   = utilisateurs.Where(u => u.EmailVerifie).Select(u => u.IdAgent!.Value).ToHashSet();
        agentsAvecCompteEnAttente = utilisateurs.Where(u => !u.EmailVerifie).Select(u => u.IdAgent!.Value).ToHashSet();
        agentIdVersUtilisateurId  = utilisateurs.ToDictionary(u => u.IdAgent!.Value, u => u.IdUtilisateur);

        var roleAgent = roles.FirstOrDefault(r => r.NomRole == Roles.Agent);
        if (roleAgent != null)
            roleCompteId = roleAgent.IdRole;
    }

    private void OuvrirModal(Agent? agent = null)
    {
        erreurMessage = null;
        agentEdite = agent != null
            ? new Agent {
                Id = agent.Id, Nom = agent.Nom, Prenom = agent.Prenom,
                Email = agent.Email, Telephone = agent.Telephone, Adresse = agent.Adresse,
                Sexe = agent.Sexe, DateNaissance = agent.DateNaissance,
                Departement = agent.Departement, Statut = agent.Statut,
                DateEmbauche = agent.DateEmbauche, Salaire = agent.Salaire,
                IdService = agent.IdService, IdPoste = agent.IdPoste
              }
            : new Agent { DateEmbauche = DateTime.Today, Statut = StatutAgent.Actif };
        var roleAgent = roles.FirstOrDefault(r => r.NomRole == Roles.Agent);
        if (roleAgent != null)
            roleCompteId = roleAgent.IdRole;
        showModal = true;
    }

    private void FermerModal()
    {
        showModal = false;
        erreurMessage = null;
    }

    private async Task Sauvegarder()
    {
        if (string.IsNullOrEmpty(agentEdite.Nom) || string.IsNullOrEmpty(agentEdite.Prenom))
        {
            erreurMessage = "Le nom et le prénom sont obligatoires.";
            return;
        }
        if (string.IsNullOrEmpty(agentEdite.Departement))
        {
            erreurMessage = "Veuillez choisir un département.";
            return;
        }
        if (agentEdite.IdService == 0 || agentEdite.IdPoste == 0)
        {
            erreurMessage = "Veuillez choisir un service et un poste.";
            return;
        }

        erreurMessage = null;
        bool estNouvel = agentEdite.Id == 0;

        if (estNouvel && string.IsNullOrWhiteSpace(agentEdite.Email))
        {
            erreurMessage = "L'email est obligatoire pour envoyer l'activation du compte.";
            return;
        }

        try
        {
            if (estNouvel)
            {
                AgentService.Add(agentEdite);
                var lien = await UtilisateurService.CreerAsync(
                    agentEdite.NomComplet,
                    agentEdite.Email,
                    roleCompteId,
                    agentEdite.Id);

                succesMessage = $"Agent et compte créés. Email d'activation envoyé. Lien (dev) : {lien}";
            }
            else
            {
                AgentService.Update(agentEdite);
                succesMessage = $"Agent {agentEdite.Prenom} {agentEdite.Nom} modifié avec succès.";
            }
        }
        catch (InvalidOperationException ex)
        {
            erreurMessage = ex.Message;
            return;
        }

        ChargerDonnees();
        showModal = false;
        showSucces = true;
        StateHasChanged();
        await Task.Delay(5000);
        showSucces = false;
        StateHasChanged();
    }

    private async Task RenvoyerVerification(int idAgent)
    {
        if (!agentIdVersUtilisateurId.TryGetValue(idAgent, out var idUtilisateur))
            return;
        try
        {
            await UtilisateurService.RenvoyerVerificationAsync(idUtilisateur);
            succesMessage = "Email d'activation renvoyé avec succès.";
            showSucces = true;
            StateHasChanged();
            await Task.Delay(4000);
            showSucces = false;
            StateHasChanged();
        }
        catch (InvalidOperationException ex)
        {
            succesMessage = ex.Message;
            showSucces = true;
            StateHasChanged();
            await Task.Delay(4000);
            showSucces = false;
            StateHasChanged();
        }
    }

    private void DemanderSuppression(Agent agent)
    {
        agentASupprimer = agent.Id;
        confirmMessage = $"Supprimer définitivement {agent.NomComplet} et son compte associé ?";
        showConfirmDelete = true;
    }

    private async Task ConfirmerSuppression()
    {
        showConfirmDelete = false;
        AgentService.Delete(agentASupprimer);
        ChargerDonnees();
        succesMessage = "Agent supprimé avec succès.";
        showSucces = true;
        StateHasChanged();
        await Task.Delay(3000);
        showSucces = false;
        StateHasChanged();
    }

    private static string GetStatutClass(string statut) => statut switch
    {
        StatutAgent.Actif => "statut-pill--actif",
        StatutAgent.EnConge => "statut-pill--conge",
        StatutAgent.Suspendu => "statut-pill--suspendu",
        StatutAgent.Archive => "statut-pill--archive",
        _ => "statut-pill--actif"
    };
}