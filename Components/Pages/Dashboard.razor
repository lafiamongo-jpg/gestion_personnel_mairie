@page "/dashboard"
@rendermode InteractiveServer
@using GestionPersonnelMairie.Core.Enums
@using GestionPersonnelMairie.Services
@using GestionPersonnelMairie.Models
@inject AgentService AgentService
@inject CongeService CongeService

<PageTitle>Tableau de bord – Gestion Personnel Mairie</PageTitle>

<div class="dash">

    <div class="dash-top">
        <div>
            <h1 class="dash-title">Tableau de bord</h1>
            <p class="dash-sub">Personnel de la Mairie de Banikoara</p>
        </div>
        <span class="dash-date">@dateDuJour</span>
    </div>

    <div class="dash-kpis">
        <div class="dash-kpi c1">
            <div class="dash-kpi-num">@totalAgents</div>
            <div class="dash-kpi-lbl">Total agents</div>
            <div class="dash-kpi-hint ok">@agentsActifs actif@(agentsActifs > 1 ? "s" : "")</div>
        </div>
        <div class="dash-kpi c2">
            <div class="dash-kpi-num">@agentsEnConge</div>
            <div class="dash-kpi-lbl">En congé</div>
            <div class="dash-kpi-hint warn">@congesEnAttente en attente</div>
        </div>
        <div class="dash-kpi c3">
            <div class="dash-kpi-num">@nbServices</div>
            <div class="dash-kpi-lbl">Services</div>
            <div class="dash-kpi-hint ok">@agentsAffectes affecté@(agentsAffectes > 1 ? "s" : "")</div>
        </div>
        <div class="dash-kpi c4">
            <div class="dash-kpi-num">@masseSalarialeStr</div>
            <div class="dash-kpi-lbl">Masse salariale</div>
            <div class="dash-kpi-hint">FCFA / mois</div>
        </div>
    </div>

    <div class="dash-panels">
        <div class="dash-panel">
            <h3 class="dash-panel-title">Répartition par service</h3>
            @if (servicesResume.Any())
            {
                @foreach (var s in servicesResume)
                {
                    <div class="dash-bar-row">
                        <div class="dash-bar-head">
                            <span>@s.Nom</span>
                            <span>@s.Count agent@(s.Count > 1 ? "s" : "")</span>
                        </div>
                        <div class="dash-bar-track">
                            <div class="dash-bar-fill" style="width:@(s.Pourcent)%;background:@s.Couleur"></div>
                        </div>
                    </div>
                }
            }
            else
            {
                <p class="dash-empty">Aucun agent enregistré.</p>
            }
        </div>

        <div class="dash-panel">
            <h3 class="dash-panel-title">Statut des agents</h3>
            @foreach (var s in statutsResume)
            {
                <div class="dash-bar-row">
                    <div class="dash-bar-head">
                        <span>@s.Label</span>
                        <span>@s.Count</span>
                    </div>
                    <div class="dash-bar-track">
                        <div class="dash-bar-fill" style="width:@(s.Pourcent)%;background:@s.Couleur"></div>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Congés en attente -->
    @if (congesEnAttenteList.Any())
    {
        <div class="dash-panel dash-panel--alert">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="dash-panel-title mb-0">
                    ⏳ Congés en attente de traitement
                    <span class="badge bg-warning text-dark ms-2">@congesEnAttenteList.Count</span>
                </h3>
                <a href="/conges" class="btn btn-sm btn-warning">Traiter →</a>
            </div>
            <div class="dash-table-wrap">
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Agent</th>
                            <th>Type</th>
                            <th>Période demandée</th>
                            <th>Soumis le</th>
                            <th>Motif</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in congesEnAttenteList)
                        {
                            <tr>
                                <td>
                                    <div class="dash-agent">
                                        <span class="dash-avatar" style="background:#fef3c7;color:#b45309;">@(d.Agent?.Initiales ?? "?")</span>
                                        <span>
                                            <strong>@d.Agent?.NomComplet</strong>
                                            <small>@d.Agent?.Email</small>
                                        </span>
                                    </div>
                                </td>
                                <td>@(d.TypeConge ?? "—")</td>
                                <td>
                                    @if (d.DateDebut.HasValue && d.DateFin.HasValue)
                                    {
                                        <span>@d.DateDebut.Value.ToString("dd/MM/yyyy") → @d.DateFin.Value.ToString("dd/MM/yyyy")</span>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td>@d.DateDemande.ToString("dd/MM/yyyy")</td>
                                <td style="max-width:180px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                    @(string.IsNullOrWhiteSpace(d.Commentaire) ? "—" : d.Commentaire)
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="dash-panel dash-panel--table">
        <h3 class="dash-panel-title">Derniers agents</h3>
        <div class="dash-table-wrap">
            <table class="dash-table">
                <thead>
                    <tr>
                        <th>Agent</th>
                        <th>Service</th>
                        <th>Poste</th>
                        <th>Embauche</th>
                        <th>Statut</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var agent in derniersAgents)
                    {
                        <tr>
                            <td>
                                <div class="dash-agent">
                                    <span class="dash-avatar">@agent.Initiales</span>
                                    <span>
                                        <strong>@agent.NomComplet</strong>
                                        <small>@agent.Email</small>
                                    </span>
                                </div>
                            </td>
                            <td>@(agent.Service?.NomService ?? "—")</td>
                            <td>@(agent.Poste?.NomPoste ?? "—")</td>
                            <td>@agent.DateEmbauche.ToString("dd/MM/yyyy")</td>
                            <td><span class="dash-badge @BadgeClass(agent.Statut)">@agent.Statut</span></td>
                        </tr>
                    }
                    @if (!derniersAgents.Any())
                    {
                        <tr><td colspan="5" class="dash-empty-cell">Aucun agent.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@code {
    private int totalAgents;
    private int agentsActifs;
    private int agentsEnConge;
    private int congesEnAttente;
    private int nbServices;
    private int agentsAffectes;
    private string masseSalarialeStr = "0";
    private string dateDuJour = "";
    private List<Agent> derniersAgents = new();
    private List<Agent> tousAgents = new();
    private List<DemandeConge> congesEnAttenteList = new();

    private record BarRow(string Nom, int Count, int Pourcent, string Couleur);
    private record StatutRow(string Label, int Count, int Pourcent, string Couleur);

    private List<BarRow> servicesResume = new();
    private List<StatutRow> statutsResume = new();

    private static readonly string[] Couleurs = ["#3b82f6", "#10b981", "#f59e0b", "#8b5cf6", "#f43f5e", "#0ea5e9"];

    protected override void OnInitialized()
    {
        var culture = new System.Globalization.CultureInfo("fr-FR");
        dateDuJour = DateTime.Now.ToString("dddd dd MMMM yyyy", culture);

        tousAgents = AgentService.GetAll();
        totalAgents = tousAgents.Count;
        agentsActifs = tousAgents.Count(a => a.Statut == StatutAgent.Actif);
        agentsEnConge = tousAgents.Count(a => a.Statut == StatutAgent.EnConge);
        var toutesLesDemandes = CongeService.GetAllDemandes();
        congesEnAttente = toutesLesDemandes.Count(d => d.Statut == "attente");
        congesEnAttenteList = toutesLesDemandes.Where(d => d.Statut == "attente").ToList();
        nbServices = AgentService.GetServices().Count;
        agentsAffectes = tousAgents.Count(a => a.IdService > 0);

        var masse = tousAgents.Sum(a => a.Salaire);
        masseSalarialeStr = masse >= 1_000_000 ? $"{masse / 1_000_000:F1}M" : masse.ToString("N0");

        derniersAgents = tousAgents.OrderByDescending(a => a.DateEmbauche).Take(5).ToList();

        var groupes = tousAgents
            .GroupBy(a => a.Service?.NomService ?? "Non affecté")
            .OrderByDescending(g => g.Count())
            .ToList();
        var maxSvc = groupes.Any() ? groupes.Max(g => g.Count()) : 1;
        servicesResume = groupes.Select((g, i) => new BarRow(
            g.Key, g.Count(), (int)((double)g.Count() / maxSvc * 100), Couleurs[i % Couleurs.Length]
        )).ToList();

        var statutCouleurs = new Dictionary<string, string>
        {
            [StatutAgent.Actif] = "#3b82f6",
            [StatutAgent.EnConge] = "#f59e0b",
            [StatutAgent.Suspendu] = "#ef4444",
            [StatutAgent.Archive] = "#94a3b8"
        };

        statutsResume = StatutAgent.All.Select(s =>
        {
            var count = tousAgents.Count(a => a.Statut == s);
            return new StatutRow(s, count,
                totalAgents > 0 ? Math.Max((int)Math.Round((double)count / totalAgents * 100), count > 0 ? 8 : 0) : 0,
                statutCouleurs[s]);
        }).ToList();
    }

    private static string BadgeClass(string statut) => statut switch
    {
        StatutAgent.Actif => "dash-badge--ok",
        StatutAgent.EnConge => "dash-badge--warn",
        StatutAgent.Suspendu => "dash-badge--err",
        _ => "dash-badge--muted"
    };
}
