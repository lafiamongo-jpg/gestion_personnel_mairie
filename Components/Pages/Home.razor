@page "/"
@rendermode InteractiveServer
@using GestionPersonnelMairie.Core.Constants
@using Microsoft.AspNetCore.Components.Authorization
@using GestionPersonnelMairie.Services
@using GestionPersonnelMairie.Models
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject AuthStateService AuthState
@inject AgentService AgentService
@inject CongeService CongeService

<PageTitle>Accueil – Gestion Personnel Mairie de Banikoara</PageTitle>

<div class="home-page">

@if (!estAuthentifie)
{
    <p>Chargement...</p>
}
else if (AuthState.PeutGererConges)
{
    <!-- ═══════════════ VUE ADMINISTRATEUR ═══════════════ -->

    <section class="hero-wrap">
        <div class="hero-bg" style="background-image: url('/images/mairie-banikoara.png')" role="presentation" aria-hidden="true"></div>
        <div class="hero-overlay" role="presentation" aria-hidden="true"></div>
        <div class="hero-inner">
            <div class="hero-left">
                <div class="hero-eyebrow">
                    <span class="pulse"></span>
                    <span>Administration — @DateTime.Now.Year</span>
                </div>
                <h1>Gestion du personnel<em>de la Mairie de Banikoara</em></h1>
                <p class="hero-desc">
                    Centralisez et administrez les ressources humaines de la commune
                    avec efficacité, transparence et rigueur institutionnelle.
                </p>
                <div class="hero-btns">
                    <button class="btn-hero-p" @onclick='() => NavigationManager.NavigateTo("/dashboard")'>
                        Tableau de bord analytique
                    </button>
                    <button class="btn-hero-g" @onclick='() => NavigationManager.NavigateTo("/agents")'>
                        Gérer les agents
                    </button>
                </div>
            </div>
            <div>
                <div class="hero-card">
                    <div class="hc-title">Vue d'ensemble — @moisCourant</div>
                    <div class="hc-stats">
                        <div class="hc-stat">
                            <div class="hc-n">@totalAgents</div>
                            <div class="hc-l">Total agents</div>
                            <div class="hc-d up">@agentsActifs actifs</div>
                        </div>
                        <div class="hc-stat">
                            <div class="hc-n">@agentsConge</div>
                            <div class="hc-l">En congé</div>
                            <div class="hc-d warn">@congesEnAttente en attente</div>
                        </div>
                        <div class="hc-stat">
                            <div class="hc-n">@masseSalarialeStr</div>
                            <div class="hc-l">Masse sal. FCFA</div>
                            <div class="hc-d neu">Mois en cours</div>
                        </div>
                        <div class="hc-stat">
                            <div class="hc-n">@nbServices</div>
                            <div class="hc-l">Services</div>
                            <div class="hc-d up">Mairie</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="home-body">
    <section class="kpi-band">
        <div class="kpi-item c1">
            <div class="kpi-num">@totalAgents</div>
            <div class="kpi-label">Total agents</div>
            <div class="kpi-delta up">@agentsActifs actifs</div>
        </div>
        <div class="kpi-item c2">
            <div class="kpi-num">@agentsConge</div>
            <div class="kpi-label">En congé</div>
            <div class="kpi-delta warn">@congesEnAttente en attente</div>
        </div>
        <div class="kpi-item c3">
            <div class="kpi-num">@nbServices</div>
            <div class="kpi-label">Services</div>
            <div class="kpi-delta up">@nbServices actif@(nbServices > 1 ? "s" : "")</div>
        </div>
        <div class="kpi-item c4">
            <div class="kpi-num">@masseSalarialeStr</div>
            <div class="kpi-label">Masse salariale (FCFA)</div>
            <div class="kpi-delta neu">Mois en cours</div>
        </div>
    </section>

    <div class="main-grid">
        <div>
            <div class="section-title">Modules du système</div>
            <div class="modules-grid">
                @if (AuthState.PeutGererAgents)
                {
                    <div class="module-card" @onclick='() => Go("/agents")'>
                        <div class="module-icon module-icon--blue">
                            <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><circle cx="9" cy="7" r="4" stroke="#2563eb" stroke-width="1.5"/><path d="M3 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2" stroke="#2563eb" stroke-width="1.5"/></svg>
                        </div>
                        <div class="module-name">Gestion des agents</div>
                        <div class="module-desc">Dossiers, profils et affectations</div>
                        <span class="badge-module badge-module--blue">@AgentLabel</span>
                    </div>
                }
                <div class="module-card" @onclick='() => Go("/conges")'>
                    <div class="module-icon module-icon--amber">
                        <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" stroke="#f59e0b" stroke-width="1.5"/><path d="M16 2v4M8 2v4M3 10h18" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round"/></svg>
                    </div>
                    <div class="module-name">Congés &amp; absences</div>
                    <div class="module-desc">Demandes, validation et soldes</div>
                    <span class="badge-module badge-module--amber">@congesEnAttente en attente</span>
                </div>
                @if (AuthState.PeutGererServices)
                {
                    <div class="module-card" @onclick='() => Go("/services")'>
                        <div class="module-icon module-icon--green">
                            <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" stroke="#10b981" stroke-width="1.5"/><path d="M3 9h18M9 21V9" stroke="#10b981" stroke-width="1.5"/></svg>
                        </div>
                        <div class="module-name">Services municipaux</div>
                        <div class="module-desc">Organisation et affectations</div>
                        <span class="badge-module badge-module--green">@nbServices services</span>
                    </div>
                }
                @if (AuthState.PeutGererAgents)
                {
                    <div class="module-card" @onclick='() => Go("/postes")'>
                        <div class="module-icon module-icon--sky">
                            <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2" stroke="#0ea5e9" stroke-width="1.5"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2" stroke="#0ea5e9" stroke-width="1.5"/></svg>
                        </div>
                        <div class="module-name">Postes</div>
                        <div class="module-desc">Vacants, occupés par service</div>
                        <span class="badge-module badge-module--sky">Gestion</span>
                    </div>
                    <div class="module-card" @onclick='() => Go("/utilisateurs")'>
                        <div class="module-icon module-icon--red">
                            <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" stroke="#dc2626" stroke-width="1.5"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="#dc2626" stroke-width="1.5"/></svg>
                        </div>
                        <div class="module-name">Utilisateurs</div>
                        <div class="module-desc">Comptes, rôles et accès</div>
                        <span class="badge-module badge-module--red">SuperAdmin</span>
                    </div>
                    <div class="module-card" @onclick='() => Go("/audit")'>
                        <div class="module-icon module-icon--violet">
                            <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke="#8b5cf6" stroke-width="1.5"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8" stroke="#8b5cf6" stroke-width="1.5" stroke-linecap="round"/></svg>
                        </div>
                        <div class="module-name">Journal d'audit</div>
                        <div class="module-desc">Connexions et actions sensibles</div>
                        <span class="badge-module badge-module--violet">Sécurité</span>
                    </div>
                }
                <div class="module-card" @onclick='() => Go("/dashboard")'>
                    <div class="module-icon module-icon--violet">
                        <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><path d="M18 20V10M12 20V4M6 20v-6" stroke="#8b5cf6" stroke-width="1.5" stroke-linecap="round"/></svg>
                    </div>
                    <div class="module-name">Tableau de bord analytique</div>
                    <div class="module-desc">Graphiques et statistiques RH</div>
                    <span class="badge-module badge-module--violet">Analytics</span>
                </div>
                <div class="module-card soon" @onclick='() => Go("/paie")'>
                    <div class="module-icon module-icon--muted">
                        <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2" stroke="#94a3b8" stroke-width="1.5"/></svg>
                    </div>
                    <div class="module-name">Fiches de paie</div>
                    <div class="module-desc">Bulletins, indemnités, primes</div>
                    <span class="badge-module badge-module--muted">Prochainement</span>
                </div>
                <div class="module-card soon" @onclick='() => Go("/evaluations")'>
                    <div class="module-icon module-icon--muted">
                        <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z" stroke="#94a3b8" stroke-width="1.5" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="module-name">Évaluations</div>
                    <div class="module-desc">Notation et avancements</div>
                    <span class="badge-module badge-module--muted">Prochainement</span>
                </div>
                <div class="module-card soon" @onclick='() => Go("/rapports")'>
                    <div class="module-icon module-icon--muted">
                        <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><path d="M18 20V10M12 20V4M6 20v-6" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round"/></svg>
                    </div>
                    <div class="module-name">Rapports &amp; exports</div>
                    <div class="module-desc">PDF, Excel, analyses</div>
                    <span class="badge-module badge-module--muted">Prochainement</span>
                </div>
            </div>

            <!-- Derniers agents -->
            <div class="section-title">Derniers agents enregistrés</div>
            <div class="activity-card">
                <div class="card-header">
                    <span>Agents récents</span>
                    <a href="#" @onclick='() => Go("/agents")' @onclick:preventDefault>Voir tous →</a>
                </div>
                @foreach (var agent in derniersAgents)
                {
                    <div class="activity-row">
                        <div class="avatar" style="background:#eff6ff;color:#2563eb">@agent.Initiales</div>
                        <div class="activity-info">
                            <div class="activity-name">@agent.NomComplet</div>
                            <div class="activity-detail">@(agent.Poste?.NomPoste ?? "-") — @(agent.Service?.NomService ?? "-")</div>
                        </div>
                        <div>
                            <span class="status-pill" style="background:@(agent.Statut=="Actif"?"#ecfdf5":"#fffbeb");color:@(agent.Statut=="Actif"?"#065f46":"#b45309")">
                                @agent.Statut
                            </span>
                            <div class="activity-time">@agent.DateEmbauche.ToShortDateString()</div>
                        </div>
                    </div>
                }
                @if (!derniersAgents.Any())
                {
                    <div class="activity-row"><div class="activity-detail text-muted">Aucun agent enregistré.</div></div>
                }
            </div>
        </div>

        <!-- SIDE -->
        <div>
            <div class="section-title">Calendrier — @moisCourant</div>
            <div class="calendar-card">
                <div class="cal-header"><span class="cal-month">@moisCourant</span></div>
                <div class="cal-grid">
                    @foreach (var d in new[]{"Lu","Ma","Me","Je","Ve","Sa","Di"})
                    { <div class="cal-day-header">@d</div> }
                    @for (int i = 0; i < debutMois; i++)
                    { <div class="cal-day other">@(joursDernierMois - debutMois + 1 + i)</div> }
                    @for (int j = 1; j <= joursInMois; j++)
                    {
                        var cls = "cal-day" + (j == today.Day ? " today" : "");
                        <div class="@cls">@j</div>
                    }
                    @for (int k = 1; k <= cellulesFin; k++)
                    { <div class="cal-day other">@k</div> }
                </div>
            </div>

            <div class="section-title">Répartition par service</div>
            <div class="dept-card">
                @foreach (var dept in departements)
                {
                    <div class="dept-row">
                        <div class="dept-info">
                            <span>@dept.Nom</span>
                            <span>@dept.NbAgents agent@(dept.NbAgents > 1 ? "s" : "")</span>
                        </div>
                        <div class="dept-bar-bg">
                            <div class="dept-bar" style="width:@dept.Pourcent%;background:@dept.Couleur"></div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <footer class="footer">
        Mairie de Banikoara &nbsp;·&nbsp; Système de Gestion du Personnel &nbsp;·&nbsp; @DateTime.Now.Year
    </footer>
    </div>
}
else
{
    <!-- ═══════════════ VUE AGENT ═══════════════ -->
    <div class="home-body home-body--agent">
    <div class="main-grid main-grid--agent">
        <div>
            <!-- Carte de bienvenue agent -->
            <div class="agent-welcome">
                <div class="agent-avatar-big">@(monAgent?.Initiales ?? "?")</div>
                <div>
                    <div class="agent-welcome-eyebrow">Bienvenue</div>
                    <div class="agent-welcome-name">@(monAgent?.NomComplet ?? AuthState.NomComplet)</div>
                    <div class="agent-welcome-meta">
                        <span>@(monAgent?.Poste?.NomPoste ?? "-")</span>
                        <span>@(monAgent?.Service?.NomService ?? "-")</span>
                        <span>@(monAgent?.Departement ?? "-")</span>
                    </div>
                </div>
            </div>

            <!-- KPIs agent -->
            <div class="agent-kpi-row">
                <div class="agent-kpi">
                    <div class="agent-kpi-num">@mesDemandes.Count</div>
                    <div class="agent-kpi-label">Demandes de congé</div>
                </div>
                <div class="agent-kpi">
                    <div class="agent-kpi-num agent-kpi-num--warn">@mesDemandes.Count(d => d.Statut == "attente")</div>
                    <div class="agent-kpi-label">En attente</div>
                </div>
                <div class="agent-kpi">
                    <div class="agent-kpi-num agent-kpi-num--ok">@mesDemandes.Count(d => d.Statut == "approuve")</div>
                    <div class="agent-kpi-label">Approuvées</div>
                </div>
            </div>

            <!-- Accès rapides -->
            <div class="section-title">Mes accès rapides</div>
            <div class="modules-grid modules-grid--agent">
                <div class="module-card" @onclick='() => Go("/conges")'>
                    <div class="module-icon module-icon--amber">
                        <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" stroke="#f59e0b" stroke-width="1.5"/><path d="M16 2v4M8 2v4M3 10h18" stroke="#f59e0b" stroke-width="1.5" stroke-linecap="round"/></svg>
                    </div>
                    <div class="module-name">Mes congés</div>
                    <div class="module-desc">Voir et soumettre des demandes de congé</div>
                    <span class="badge-module badge-module--amber">@mesDemandes.Count(d=>d.Statut=="attente") en attente</span>
                </div>
                <div class="module-card soon" @onclick='() => Go("/paie")'>
                    <div class="module-icon module-icon--muted">
                        <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2" stroke="#94a3b8" stroke-width="1.5"/></svg>
                    </div>
                    <div class="module-name">Mes bulletins de paie</div>
                    <div class="module-desc">Consulter mes fiches de paie mensuelles</div>
                    <span class="badge-module badge-module--muted">Prochainement</span>
                </div>
                <div class="module-card soon" @onclick='() => Go("/evaluations")'>
                    <div class="module-icon module-icon--muted">
                        <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z" stroke="#94a3b8" stroke-width="1.5" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="module-name">Mes évaluations</div>
                    <div class="module-desc">Consulter mes évaluations annuelles</div>
                    <span class="badge-module badge-module--muted">Prochainement</span>
                </div>
                <div class="module-card" @onclick='() => Go("/profil")'>
                    <div class="module-icon module-icon--sky">
                        <svg width="20" height="20" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="8" r="4" stroke="#0ea5e9" stroke-width="1.5"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="#0ea5e9" stroke-width="1.5"/></svg>
                    </div>
                    <div class="module-name">Mon profil</div>
                    <div class="module-desc">Informations personnelles et mot de passe</div>
                    <span class="badge-module badge-module--sky">Profil</span>
                </div>
            </div>

            <!-- Mes dernières demandes -->
            <div class="section-title">Mes dernières demandes de congé</div>
            <div class="demandes-table">
                <table>
                    <thead>
                        <tr>
                            <th>Date demande</th>
                            <th>Motif</th>
                            <th>Statut</th>
                            <th>Période accordée</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in mesDemandes.Take(5))
                        {
                            <tr>
                                <td>@d.DateDemande.ToShortDateString()</td>
                                <td>@(d.Commentaire ?? "-")</td>
                                <td>
                                    <span class="status-pill" style="background:@GetBg(d.Statut);color:@GetFg(d.Statut)">
                                        @GetLabel(d.Statut)
                                    </span>
                                </td>
                                <td>
                                    @if (d.Conge != null)
                                    {
                                        @($"{d.Conge.DateDebut:dd/MM/yy} → {d.Conge.DateFin:dd/MM/yy} ({d.Conge.Duree}j)")
                                    }
                                    else { <span class="text-muted">-</span> }
                                </td>
                            </tr>
                        }
                        @if (!mesDemandes.Any())
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">Aucune demande.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <footer class="footer">
        Mairie de Banikoara &nbsp;·&nbsp; Système de Gestion du Personnel &nbsp;·&nbsp; @DateTime.Now.Year
    </footer>
    </div>
}

</div>

@code {
    private bool estAuthentifie = false;
    private Agent? monAgent;
    private List<DemandeConge> mesDemandes = new();

    // Stats admin
    private int totalAgents;
    private int agentsActifs;
    private int agentsConge;
    private int congesEnAttente;
    private int nbServices;
    private string AgentLabel => totalAgents <= 1 ? $"{totalAgents} agent" : $"{totalAgents} agents";
    private string masseSalarialeStr = "0";
    private List<Agent> derniersAgents = new();

    // Calendrier
    private DateTime today = DateTime.Today;
    private string moisCourant = "";
    private int debutMois, joursInMois, joursDernierMois, cellulesFin;

    private record Dept(string Nom, int Pourcent, int NbAgents, string Couleur);
    private List<Dept> departements = new();

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        estAuthentifie = state.User.Identity?.IsAuthenticated ?? false;
        if (!estAuthentifie) { NavigationManager.NavigateTo("/login"); return; }

        // Calendrier
        var culture = new System.Globalization.CultureInfo("fr-FR");
        moisCourant = today.ToString("MMMM yyyy", culture);
        moisCourant = char.ToUpper(moisCourant[0]) + moisCourant[1..];
        var premierJour = new DateTime(today.Year, today.Month, 1);
        debutMois = ((int)premierJour.DayOfWeek + 6) % 7;
        joursInMois = DateTime.DaysInMonth(today.Year, today.Month);
        joursDernierMois = DateTime.DaysInMonth(today.Month == 1 ? today.Year - 1 : today.Year, today.Month == 1 ? 12 : today.Month - 1);
        int total = debutMois + joursInMois;
        cellulesFin = total % 7 == 0 ? 0 : 7 - (total % 7);

        if (AuthState.PeutGererConges)
        {
            var agents = AgentService.GetAll();
            totalAgents = agents.Count;
            agentsActifs = agents.Count(a => a.Statut == "Actif");
            agentsConge = agents.Count(a => a.Statut == "En congé");
            nbServices = AgentService.GetServices().Count;
            var masse = agents.Sum(a => a.Salaire);
            masseSalarialeStr = masse >= 1_000_000 ? $"{masse / 1_000_000:F1}M" : masse.ToString("N0");
            derniersAgents = agents.OrderByDescending(a => a.DateEmbauche).Take(5).ToList();
            congesEnAttente = CongeService.GetAllDemandes().Count(d => d.Statut == "attente");

            var groupes = agents.GroupBy(a => a.Service?.NomService ?? "Non affecté")
                .OrderByDescending(g => g.Count()).Take(5).ToList();
            int max = groupes.Any() ? groupes.Max(g => g.Count()) : 1;
            var couleurs = new[] { "#2563eb","#10b981","#f59e0b","#8b5cf6","#f43f5e" };
            departements = groupes.Select((g, i) => new Dept(
                g.Key, (int)((double)g.Count() / max * 100), g.Count(), couleurs[i % couleurs.Length]
            )).ToList();
        }
        else if (AuthState.AgentId.HasValue)
        {
            monAgent = AgentService.GetById(AuthState.AgentId.Value);
            mesDemandes = CongeService.GetDemandesByAgent(AuthState.AgentId.Value);
        }
    }

    private string GetBg(string s) => s switch { "approuve" => "#ecfdf5", "refuse" => "#fef2f2", _ => "#fffbeb" };
    private string GetFg(string s) => s switch { "approuve" => "#065f46", "refuse" => "#991b1b", _ => "#b45309" };
    private string GetLabel(string s) => s switch { "approuve" => "Approuvé", "refuse" => "Refusé", _ => "En attente" };
    private void Go(string url) => NavigationManager.NavigateTo(url);
}
