@page "/login"
@layout EmptyLayout
@rendermode InteractiveServer
@using GestionPersonnelMairie.Core.Constants
@using GestionPersonnelMairie.Services
@inject AuthService AuthService
@inject CustomAuthStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Connexion — Mairie de Banikoara</PageTitle>

<div id="login-screen"
     style="min-height:100vh;position:relative;display:flex !important;align-items:center !important;justify-content:center !important;
            background:url('/images/mairie-banikoara.png') center/cover no-repeat;padding:2rem;box-sizing:border-box;">

    <!-- Overlay sur toute la page -->
    <div style="position:absolute;inset:0;z-index:0;
                background:linear-gradient(105deg,rgba(10,22,40,0.75) 0%,rgba(10,22,40,0.45) 50%,rgba(10,22,40,0.35) 100%),
                           linear-gradient(to top,rgba(10,22,40,0.6) 0%,transparent 45%);"
         aria-hidden="true"></div>

    <!-- Texte institutionnel en bas à gauche -->
    <div style="position:absolute;bottom:0;left:0;z-index:1;padding:2.5rem 3rem;color:#fff;max-width:480px;">
        <div style="font-size:0.72rem;letter-spacing:0.16em;text-transform:uppercase;color:#dbb84a;margin-bottom:0.6rem;font-weight:600;">
            République du Bénin
        </div>
        <h1 style="font-family:'Instrument Serif',Georgia,serif;font-size:2.2rem;font-weight:400;line-height:1.1;margin-bottom:0.5rem;">
            Commune de Banikoara
        </h1>
        <p style="color:rgba(255,255,255,0.8);font-size:0.88rem;line-height:1.5;margin:0;">
            Système de gestion automatisée du personnel municipal.
        </p>
    </div>

    <!-- Carte blanche centrée -->
    <div style="position:relative;z-index:2;width:100%;max-width:420px;
                background:rgba(245, 242, 235, 0.92);
                backdrop-filter:blur(12px);
                border-radius:16px;padding:2rem;
                box-shadow:0 16px 48px rgba(10,22,40,0.22);
                border:1px solid rgba(255,255,255,0.45);">

            @if (mode == "login")
            {
                <h2 style="font-size:1.45rem;font-weight:700;color:#0f2137;margin-bottom:0.2rem;">Connexion</h2>
                <p style="color:#64748b;font-size:0.88rem;margin-bottom:1.5rem;">Mairie de Banikoara — Gestion du personnel</p>

                <div class="mb-3">
                    <label class="form-label small text-muted">Email</label>
                    <input class="form-control" placeholder="votre.email@exemple.bj"
                           @bind="email" @bind:event="oninput" />
                </div>

                <div class="mb-2">
                    <label class="form-label small text-muted">Mot de passe</label>
                    <div style="position:relative;">
                        <input type="@(showPassword ? "text" : "password")"
                               class="form-control" placeholder="••••••••"
                               @bind="motPasse" style="padding-right:4.5rem;" />
                        <button type="button" @onclick="TogglePassword"
                                style="position:absolute;right:8px;top:50%;transform:translateY(-50%);
                                       background:none;border:none;color:#94a3b8;font-size:0.78rem;cursor:pointer;">
                            @(showPassword ? "Masquer" : "Afficher")
                        </button>
                    </div>
                </div>

                <div class="text-end mb-4">
                    <a href="#" class="small" style="color:#1a3a6b;" @onclick="GoForgot" @onclick:preventDefault>Mot de passe oublié ?</a>
                </div>

                <p style="font-size:0.8rem;font-weight:600;color:#475569;margin-bottom:0.65rem;">Se connecter en tant que</p>
                <div style="display:flex;flex-direction:column;gap:0.55rem;">
                    <button type="button"
                            style="width:100%;padding:0.78rem 1rem;border:none;border-radius:8px;font-weight:600;
                                   font-size:0.86rem;cursor:pointer;color:#fff;background:#1a3a6b;"
                            @onclick='() => SeConnecter(Roles.Agent)' disabled="@chargement">
                        @(chargementRole == Roles.Agent ? "Connexion..." : "Se connecter en tant qu'Agent")
                    </button>
                    <button type="button"
                            style="width:100%;padding:0.78rem 1rem;border:none;border-radius:8px;font-weight:600;
                                   font-size:0.86rem;cursor:pointer;color:#fff;background:#9a7b1a;"
                            @onclick='() => SeConnecter(Roles.Admin)' disabled="@chargement">
                        @(chargementRole == Roles.Admin ? "Connexion..." : "Se connecter en tant qu'Administrateur")
                    </button>
                    <button type="button"
                            style="width:100%;padding:0.78rem 1rem;border:none;border-radius:8px;font-weight:600;
                                   font-size:0.86rem;cursor:pointer;color:#fff;background:#0a1628;"
                            @onclick='() => SeConnecter(Roles.SuperAdmin)' disabled="@chargement">
                        @(chargementRole == Roles.SuperAdmin ? "Connexion..." : "Se connecter en tant que Super Administrateur")
                    </button>
                </div>

                <div style="margin-top:1.2rem;padding:0.75rem 0.9rem;background:rgba(230,236,228,0.7);
                            border-left:3px solid #c9a227;border-radius:0 8px 8px 0;
                            font-size:0.78rem;color:#475569;line-height:1.5;">
                    Compte créé par le Super Admin. Activez-le via l'email reçu,
                    connectez-vous avec <strong>@AppDefaults.MotDePasseInitial</strong>,
                    puis modifiez votre mot de passe dans <em>Mon profil</em>.
                </div>
            }

            @if (mode == "forgot")
            {
                <button type="button" style="background:none;border:none;color:#64748b;font-size:0.82rem;padding:0;margin-bottom:1rem;cursor:pointer;"
                        @onclick="GoLogin">← Retour</button>
                <h2 style="font-size:1.45rem;font-weight:700;color:#0f2137;">Mot de passe oublié</h2>
                <p style="color:#64748b;font-size:0.88rem;margin-bottom:1rem;">Entrez votre email pour recevoir un code.</p>
                <input class="form-control" placeholder="Votre email" @bind="email" @bind:event="oninput" />
                <button class="btn btn-primary w-100 mt-3" @onclick="EnvoyerCode" disabled="@chargementForgot">
                    @(chargementForgot ? "Envoi..." : "Envoyer le code")
                </button>
            }

            @if (mode == "verify")
            {
                <button type="button" style="background:none;border:none;color:#64748b;font-size:0.82rem;padding:0;margin-bottom:1rem;cursor:pointer;"
                        @onclick="GoForgot">← Changer d'email</button>
                <h2 style="font-size:1.45rem;font-weight:700;color:#0f2137;">Vérification</h2>
                <p style="color:#64748b;font-size:0.88rem;">
                    Saisissez le code à 6 chiffres.<br /><strong>Code (démo) : @codeDemo</strong>
                </p>
                <div style="display:flex;gap:8px;justify-content:center;margin:1rem 0;">
                    <input maxlength="1" class="form-control text-center" style="width:42px;" @bind="otp1" @oninput="@(e => OtpSaisi(e, 1))" />
                    <input maxlength="1" class="form-control text-center" style="width:42px;" @bind="otp2" @oninput="@(e => OtpSaisi(e, 2))" />
                    <input maxlength="1" class="form-control text-center" style="width:42px;" @bind="otp3" @oninput="@(e => OtpSaisi(e, 3))" />
                    <input maxlength="1" class="form-control text-center" style="width:42px;" @bind="otp4" @oninput="@(e => OtpSaisi(e, 4))" />
                    <input maxlength="1" class="form-control text-center" style="width:42px;" @bind="otp5" @oninput="@(e => OtpSaisi(e, 5))" />
                    <input maxlength="1" class="form-control text-center" style="width:42px;" @bind="otp6" @oninput="@(e => OtpSaisi(e, 6))" />
                </div>
                <button class="btn btn-primary w-100" @onclick="ValiderCode">Vérifier le code</button>
            }

            @if (mode == "reset")
            {
                <h2 style="font-size:1.45rem;font-weight:700;color:#0f2137;">Nouveau mot de passe</h2>
                <input type="password" class="form-control mt-3" placeholder="Nouveau mot de passe" @bind="nouveauMotPasse" />
                <input type="password" class="form-control mt-2" placeholder="Confirmer" @bind="confirmerMotPasse" />
                <button class="btn btn-primary w-100 mt-3" @onclick="ConfirmerReinitialisation"
                        disabled="@(!PeutSauvegarder())">Enregistrer</button>
            }

            @if (erreur != null)
            {
                <div class="alert alert-danger mt-3 mb-0 py-2" style="font-size:0.85rem;">@erreur</div>
            }
            @if (succes != null)
            {
                <div class="alert alert-success mt-3 mb-0 py-2" style="font-size:0.85rem;">@succes</div>
            }
    </div>
</div>

@code {
    private string email = "";
    private string motPasse = "";
    private string confirmerMotPasse = "";
    private string nouveauMotPasse = "";
    private string otp1 = "", otp2 = "", otp3 = "", otp4 = "", otp5 = "", otp6 = "";
    private string codeDemo = "";

    private string? erreur;
    private string? succes;
    private bool chargement;
    private string? chargementRole;
    private bool chargementForgot;
    private bool showPassword;
    private string mode = "login";

    private void TogglePassword() => showPassword = !showPassword;

    private void GoLogin() { mode = "login"; Reset(); }
    private void GoForgot() { mode = "forgot"; Reset(); }

    private void Reset()
    {
        erreur = null; succes = null;
        motPasse = ""; confirmerMotPasse = ""; nouveauMotPasse = "";
        otp1 = otp2 = otp3 = otp4 = otp5 = otp6 = "";
    }

    private async Task SeConnecter(string role)
    {
        erreur = null; succes = null;

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(motPasse))
        {
            erreur = "Veuillez saisir votre email et votre mot de passe.";
            return;
        }

        chargement = true;
        chargementRole = role;
        try
        {
            var result = AuthService.Login(email, motPasse);
            var roleCompte = result.Utilisateur.Role?.NomRole ?? "";

            if (roleCompte != role)
            {
                erreur = $"Ce compte n'est pas un compte {GetRoleLabel(role)}. Rôle attribué : {GetRoleLabel(roleCompte)}.";
                return;
            }

            await AuthStateProvider.LoginWithResultAsync(result);
            Navigation.NavigateTo("/");
        }
        catch (UnauthorizedAccessException ex) { erreur = ex.Message; }
        catch (Exception ex) { erreur = "Erreur : " + ex.Message; }
        finally { chargement = false; chargementRole = null; }
    }

    private async Task EnvoyerCode()
    {
        erreur = null; succes = null;
        if (string.IsNullOrWhiteSpace(email)) { erreur = "Veuillez entrer votre adresse email."; return; }

        chargementForgot = true;
        try
        {
            if (!AuthService.EmailExiste(email)) { succes = "Si cet email est enregistré, un code a été généré."; return; }
            codeDemo = await AuthService.GenererTokenReinitialisationAsync(email);
            mode = "verify";
            succes = "Code généré. Saisissez-le ci-dessous.";
        }
        catch (Exception ex) { erreur = "Erreur : " + ex.Message; }
        finally { chargementForgot = false; }
    }

    private void OtpSaisi(ChangeEventArgs e, int index)
    {
        var v = e.Value?.ToString() ?? "";
        switch (index) { case 1: otp1 = v; break; case 2: otp2 = v; break; case 3: otp3 = v; break;
            case 4: otp4 = v; break; case 5: otp5 = v; break; case 6: otp6 = v; break; }
    }

    private void ValiderCode()
    {
        erreur = null; succes = null;
        var code = otp1 + otp2 + otp3 + otp4 + otp5 + otp6;
        if (code.Length < 6) { erreur = "Veuillez saisir les 6 chiffres."; return; }
        if (!AuthService.ValiderToken(email, code)) { erreur = "Code incorrect ou expiré."; return; }
        mode = "reset";
    }

    private bool PeutSauvegarder() => nouveauMotPasse.Length >= 6 && nouveauMotPasse == confirmerMotPasse;

    private void ConfirmerReinitialisation()
    {
        erreur = null; succes = null;
        if (!PeutSauvegarder()) { erreur = "Vérifiez les conditions du mot de passe."; return; }
        try
        {
            AuthService.ReinitialisMotDePasse(email, nouveauMotPasse);
            succes = "Mot de passe mis à jour ! Redirection...";
            Task.Delay(2000).ContinueWith(_ => InvokeAsync(() => { GoLogin(); StateHasChanged(); }));
        }
        catch (Exception ex) { erreur = "Erreur : " + ex.Message; }
    }

    private static string GetRoleLabel(string role) => role switch
    {
        Roles.Admin => "Administrateur",
        Roles.SuperAdmin => "Super Administrateur",
        _ => "Agent"
    };
}
